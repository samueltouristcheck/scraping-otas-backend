# Sin Docker: PostgreSQL nativo (Windows) + .\setup-local.ps1 y .\run-api-local.ps1 en esta carpeta.
APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=ota_intel
POSTGRES_USER=ota_user
POSTGRES_PASSWORD=ota_password
POSTGRES_PORT=5432

API_HOST=0.0.0.0
API_PORT=8000
# Local + dominios custom en Vercel. Los despliegues en *.vercel.app los admite la API por regex (ver api/main.py).
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+asyncpg://ota_user:ota_password@localhost:5432/ota_intel

SCHEDULER_TZ=Europe/Madrid
SCHEDULER_CRON=0 */2 * * *
# Local: false para no scrapear en tu PC. En Render (Background Worker) puedes poner true si quieres un ciclo al desplegar; si no, solo corre el cron.
SCHEDULER_RUN_ON_STARTUP=false
GYG_MONITORED_TOURS_JSON=[]
# Si True: solo scrapea ventana futura (GYG_FORWARD_*). Si False: desde hoy, hasta GYG_DAILY_HORIZON_DAYS.
GYG_FUTURE_ONLY=true
# Primer día de visita: 1 = mañana (no scrapea “ayer” como visita).
GYG_FORWARD_START_OFFSET_DAYS=1
# Cuántos días seguidos hacia adelante (14 ≈ dos semanas).
GYG_FORWARD_WINDOW_DAYS=14
# Solo usado si GYG_FUTURE_ONLY=false — ventana 0..N desde hoy.
GYG_DAILY_HORIZON_DAYS=180
MONITORED_TOURS_JSON=[]
VIATOR_MONITORED_TOURS_JSON=[]
VIATOR_SCHEDULER_CRON=0 */2 * * *
# true = sin ventana de Chromium (recomendado en Windows si no quieres que se abra el navegador al scrapear Viator).
VIATOR_HEADLESS=true

# Opcional: mismo valor que VITE_SCRAPING_TRIGGER_TOKEN en el frontend; habilita POST /api/v1/scraping/trigger
# SCRAPING_TRIGGER_SECRET=

# Scraping real: ver REAL_SCRAPING.md y JSON de ejemplo en config/
